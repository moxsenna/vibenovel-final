# Copy to `.env.staging` for Node/Docker staging — NEVER commit `.env.staging`
# Task 11.4 Mode A safe defaults (names only; fill secrets via operator)

APP_ENV=staging
ALLOWED_ORIGINS=http://localhost:5173,https://vibenovel-web-staging.pages.dev

# Hosted Supabase (operator — leave empty for health-only shell)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mode A — payment disabled
CREDIT_TOPUP_ENABLED=false
PAYMENT_PROVIDER=mock
PAYMENT_PROVIDER_MOCK=true
PAYMENT_PROVIDER_MOCK_MODE=success

# Mode A — AI disabled
AI_GENERATION_ENABLED=false
AI_PROVIDER_MOCK=true

# Node/Docker listen port (internal; Caddy terminates TLS on 443)
PORT=8787

# Mode B only — Duitku sandbox (Task 10.13b); copy secrets to gitignored .env.staging.duitku
# CREDIT_TOPUP_ENABLED=true
# PAYMENT_PROVIDER=duitku
# PAYMENT_PROVIDER_MOCK=false
# DUITKU_ENV=sandbox
# DUITKU_MERCHANT_CODE=
# DUITKU_MERCHANT_KEY=
# DUITKU_CALLBACK_URL=https://api-staging.narraza.web.id/api/payments/duitku/callback
# DUITKU_RETURN_URL=https://vibenovel-web-staging.pages.dev/credits/topup/return
# MAYAR_API_KEY=
# OPENROUTER_API_KEY=