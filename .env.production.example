# Copy to `.env.production` for production Supabase + future EC2 API — NEVER commit `.env.production`
# Task 10.21 — production baseline only (names only; fill via operator from new Supabase account)

APP_ENV=production
# Domain model (Task 10.23a):
#   narraza.web.id      = homepage / landing / marketing (NOT the dashboard)
#   app.narraza.web.id  = app / dashboard (Cloudflare Pages)
#   api.narraza.web.id  = API (AWS EC2 + Caddy)
ALLOWED_ORIGINS=https://narraza.web.id,https://www.narraza.web.id,https://app.narraza.web.id

# Dedicated production Supabase (MUST NOT be staging ref jdxyhrnibmmwlbtbokqo)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CLI auth for production account (not staging account) — never commit
# SUPABASE_ACCESS_TOKEN=

# Database password for `supabase link --password` / `db push` — never commit
# SUPABASE_DB_PASSWORD=

# Mode A — payment disabled until docs/73 founder Go
CREDIT_TOPUP_ENABLED=false
PAYMENT_PROVIDER=mock
PAYMENT_PROVIDER_MOCK=true
PAYMENT_PROVIDER_MOCK_MODE=success

# AI disabled until separate Go
AI_GENERATION_ENABLED=false
AI_PROVIDER_MOCK=true
# OpenRouter — API server ONLY (EC2 .env.production). Never in apps/web or git.
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# To enable live AI after founder approval: AI_GENERATION_ENABLED=true, AI_PROVIDER_MOCK=false, restart API.
# Hemat tier default gemma-2-9b-it may 404 on OpenRouter — set working allowlisted model:
# AI_MODEL_HEMAT=google/gemini-2.5-flash

PORT=8787

# Duitku production — DO NOT SET until payment enablement (docs/73)
# DUITKU_ENV=production
# DUITKU_MERCHANT_CODE=
# DUITKU_MERCHANT_KEY=
# DUITKU_CALLBACK_URL=https://api.narraza.web.id/api/payments/duitku/callback
# DUITKU_RETURN_URL=https://app.narraza.web.id/credits/topup/return

# Web production build (Cloudflare Pages app — never commit keys)
# VITE_API_URL=https://api.narraza.web.id
# VITE_PUBLIC_SITE_URL=https://narraza.web.id
# VITE_APP_URL=https://app.narraza.web.id
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_USE_MOCKS=false