# Copy to `.env.local` for local dev тАФ never commit real keys
# Values from `supabase status` after `supabase start`

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# API Worker (Task 2.13)
VITE_API_URL=http://127.0.0.1:8787

# Mock fallback тАФ default true keeps Sprint 1 UI stable when API is offline
# Set to false + Supabase login for API mode:
#   dashboard, settings, foundation (Task 2.13)
#   intake, concepts, foundation proposals/readiness/lock (Task 3.6)
#   outline cerita generate/edit/approve/lock (Task 4.6); E2E smoke (Task 4.8)
#   write room session/beats/prose/context preview (Task 5.5)
#   summary page generate/delta/approve/proposal review (Task 6.5)
#   publish page load/generate/edit/checklist/mark-exported (Task 7.4)
#   WritePage AI generate button (Task 8.5) - requires API mode + dev:api with AI enabled for real generation
#   WritePage rewrite UI Perbaiki Teks (Task 9.4) - API mode only; mock/fallback shows disabled explanation
VITE_USE_MOCKS=true