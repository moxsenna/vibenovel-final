# Copy to `.dev.vars` for local `wrangler dev` — never commit `.dev.vars`
# Values from `supabase status` after `supabase start`

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Sprint 8 AI generation (Task 8.1+ — names only; never commit values)
# AI_GENERATION_ENABLED=false
# AI_PROVIDER_MOCK=false
# AI_PROVIDER_MOCK_MODE=success
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_AI_MODEL=
# AI_MODEL_HEMAT=google/gemma-2-9b-it
# AI_MODEL_SEIMBANG=anthropic/claude-3-haiku
# AI_MODEL_TERBAIK=anthropic/claude-3.5-sonnet
# AI_TIMEOUT_MS=45000
# AI_MAX_RETRIES=1
# AI_CREDIT_COST_PROSE_BEAT=10
# AI_CREDIT_COST_PROSE_REWRITE=8
# AI_CREDIT_COST_PUBLISH_COPY=5