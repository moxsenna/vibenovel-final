# Copy to `.dev.vars` for local `wrangler dev` — never commit `.dev.vars`
# Values from `supabase status` after `supabase start`

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Sprint 8 AI generation (Task 8.4 — names only; never commit values)
# Default: AI disabled. For local sprint8 smoke set both true and restart dev:api.
# AI_GENERATION_ENABLED=false
# AI_PROVIDER_MOCK=true
# AI_PROVIDER_MOCK_MODE=success
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_AI_MODEL=
# AI_MODEL_HEMAT=google/gemma-2-9b-it
# AI_MODEL_HEMAT=google/gemini-flash-latest
# AI_MODEL_HEMAT=google/gemini-2.0-flash-001
# AI_MODEL_HEMAT=google/gemini-2.5-flash
# AI_MODEL_SEIMBANG=anthropic/claude-3-haiku
# AI_MODEL_TERBAIK=anthropic/claude-3.5-sonnet
# AI_TIMEOUT_MS=45000
# AI_MAX_RETRIES=1
# AI_CREDIT_COST_PROSE_BEAT=10
# AI_CREDIT_COST_PROSE_REWRITE=8
# AI_CREDIT_COST_PUBLISH_COPY=5

# Sprint 10 payment topup (Task 10.2 — names only; never commit values)
# Default: topup disabled. For local sprint10 smoke set enabled + mock and restart dev:api.
# CREDIT_TOPUP_ENABLED=false
# PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER_MOCK=true
# PAYMENT_PROVIDER_MOCK_MODE=success
# PAYMENT_RETURN_BASE_URL=http://localhost:5173
# MAYAR_API_KEY=
# MAYAR_BASE_URL=https://api.mayar.club/hl/v1
# MAYAR_ENV=sandbox
# MAYAR_REDIRECT_BASE_URL=http://localhost:5173
# PAYMENT_TIMEOUT_MS=30000

# Sprint 10 Duitku POP (Task 10.10 — names only; never commit values)
# PAYMENT_PROVIDER=duitku
# DUITKU_MERCHANT_CODE=
# DUITKU_MERCHANT_KEY=
# DUITKU_ENV=sandbox
# DUITKU_BASE_URL=https://api-sandbox.duitku.com
# DUITKU_CALLBACK_URL=http://127.0.0.1:8787/api/payments/duitku/callback
# DUITKU_RETURN_URL=http://localhost:5173

# Sprint 10.12 Duitku callback smoke fixture (Task 10.12 — local development only)
# When real Duitku keys are unset, development auto-enables fixture credentials for callback smoke.
# Optional explicit override:
# DUITKU_SMOKE_CALLBACK_FIXTURE=true