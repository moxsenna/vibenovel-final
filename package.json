{
  "name": "vibenovel",
  "private": true,
  "version": "0.1.0",
  "description": "VibeNovel — AI Serial Fiction Production OS (monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @vibenovel/web",
    "dev:api": "npm run dev -w @vibenovel/api",
    "dev:api:node": "npm run dev:node -w @vibenovel/api",
    "build:api:node": "npm run build:shared && npm run build:node -w @vibenovel/api",
    "start:api:node": "npm run start:node -w @vibenovel/api",
    "build:web": "npm run build -w @vibenovel/web",
    "build:api": "npm run build:shared && npm run build -w @vibenovel/api",
    "deploy:api:staging": "npm run build:shared && npm run deploy:staging -w @vibenovel/api",
    "deploy:web:staging": "npm run build:web && npx wrangler pages deploy apps/web/dist --project-name vibenovel-web-staging --branch main --commit-dirty=true",
    "smoke:staging:health": "powershell -ExecutionPolicy Bypass -File scripts/staging-health-smoke.ps1",
    "smoke:staging": "powershell -ExecutionPolicy Bypass -File scripts/smoke-staging.ps1",
    "operator:staging:supabase-gate": "powershell -ExecutionPolicy Bypass -File scripts/operator-staging-supabase-gate.ps1",
    "operator:staging:worker-secrets": "powershell -ExecutionPolicy Bypass -File scripts/operator-staging-worker-secrets.ps1",
    "operator:aws:staging:smoke": "powershell -ExecutionPolicy Bypass -File scripts/operator-aws-ec2-staging-smoke.ps1",
    "operator:aws:https:gate": "powershell -ExecutionPolicy Bypass -File scripts/operator-aws-https-web-gate.ps1",
    "operator:aws:duitku:gate": "powershell -ExecutionPolicy Bypass -File scripts/operator-aws-duitku-mode-b.ps1",
    "build:shared": "npm run build -w @vibenovel/shared",
    "typecheck": "npm run typecheck -w @vibenovel/shared && npm run typecheck -w @vibenovel/web && npm run typecheck -w @vibenovel/api",
    "typecheck:shared": "npm run typecheck -w @vibenovel/shared",
    "typecheck:web": "npm run typecheck -w @vibenovel/web",
    "typecheck:api": "npm run typecheck -w @vibenovel/api",
    "test:duitku-signature": "npm run test:duitku-signature -w @vibenovel/api",
    "test:atomic-grant": "npm run test:atomic-grant -w @vibenovel/api",
    "test:atomic-grant-hosted": "npm run test:atomic-grant-hosted -w @vibenovel/api",
    "operator:staging:atomic-grant": "powershell -ExecutionPolicy Bypass -File scripts/operator-verify-hosted-atomic-grant.ps1",
    "operator:production:supabase:baseline": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-supabase-baseline.ps1",
    "operator:production:api-web:deploy": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-api-web-deploy.ps1",
    "operator:production:infra:unblock": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-infra-unblock.ps1",
    "operator:production:ec2:provision": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-ec2-provision.ps1",
    "operator:production:aws:deploy": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-aws-deploy.ps1",
    "operator:production:sync-env": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-sync-env.ps1",
    "build:web:production": "powershell -ExecutionPolicy Bypass -File scripts/build-production-web.ps1",
    "deploy:web:production": "npm run build:web:production && npx wrangler pages deploy apps/web/dist --project-name narraza-web-production --branch main --commit-dirty=true",
    "build:homepage:production": "powershell -ExecutionPolicy Bypass -File scripts/build-production-homepage.ps1",
    "deploy:homepage:production": "npm run build:homepage:production && npx wrangler pages deploy apps/homepage/dist --project-name narraza-homepage-production --branch main --commit-dirty=true",
    "operator:production:homepage:deploy": "powershell -ExecutionPolicy Bypass -File scripts/operator-production-homepage-deploy.ps1",
    "preview:web": "npm run preview -w @vibenovel/web",
    "smoke:api": "powershell -ExecutionPolicy Bypass -File scripts/sprint2-smoke-api.ps1",
    "smoke:api:base": "powershell -ExecutionPolicy Bypass -File scripts/sprint2-smoke-api.ps1",
    "smoke:api:sprint5": "powershell -ExecutionPolicy Bypass -File scripts/sprint5-smoke-api.ps1",
    "smoke:api:sprint6": "powershell -ExecutionPolicy Bypass -File scripts/sprint6-smoke-api.ps1",
    "smoke:api:sprint7": "powershell -ExecutionPolicy Bypass -File scripts/sprint7-smoke-api.ps1",
    "smoke:api:sprint8": "powershell -ExecutionPolicy Bypass -File scripts/sprint8-smoke-api.ps1",
    "smoke:api:sprint9": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-api.ps1",
    "smoke:api:sprint10": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-smoke-api.ps1",
    "smoke:api:sprint10:dual-app": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-dual-app-smoke.ps1",
    "smoke:api:sprint10:mayar-live": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-mayar-live-smoke.ps1",
    "smoke:api:sprint10:duitku": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-duitku-smoke-api.ps1",
    "smoke:web:topup": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-smoke-web.ps1",
    "smoke:web:sprint10": "powershell -ExecutionPolicy Bypass -File scripts/sprint10-smoke-web.ps1",
    "smoke:web": "powershell -ExecutionPolicy Bypass -File scripts/sprint3-smoke-web.ps1",
    "smoke:web:outline": "powershell -ExecutionPolicy Bypass -File scripts/sprint4-smoke-web.ps1",
    "smoke:web:write": "powershell -ExecutionPolicy Bypass -File scripts/sprint5-smoke-web.ps1",
    "smoke:web:write-ai": "powershell -ExecutionPolicy Bypass -File scripts/sprint8-smoke-web.ps1",
    "smoke:web:credit-ui": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:rewrite": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:sprint9": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:publish-ai": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1 -PublishAiOnly",
    "smoke:web:summary": "powershell -ExecutionPolicy Bypass -File scripts/sprint6-smoke-web.ps1",
    "smoke:web:publish": "powershell -ExecutionPolicy Bypass -File scripts/sprint7-smoke-web.ps1",
    "smoke:all:local": "powershell -ExecutionPolicy Bypass -File scripts/smoke-all-local.ps1",
    "smoke:all:local:full": "powershell -ExecutionPolicy Bypass -File scripts/smoke-all-local.ps1 -IncludeApiMode"
  },
  "engines": {
    "node": ">=18"
  }
}