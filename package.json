{
  "name": "vibenovel",
  "private": true,
  "version": "0.1.0",
  "description": "VibeNovel — AI Serial Fiction Production OS (monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @vibenovel/web",
    "dev:api": "npm run dev -w @vibenovel/api",
    "build:web": "npm run build -w @vibenovel/web",
    "build:api": "npm run build:shared && npm run build -w @vibenovel/api",
    "build:shared": "npm run build -w @vibenovel/shared",
    "typecheck": "npm run typecheck -w @vibenovel/shared && npm run typecheck -w @vibenovel/web && npm run typecheck -w @vibenovel/api",
    "typecheck:shared": "npm run typecheck -w @vibenovel/shared",
    "typecheck:web": "npm run typecheck -w @vibenovel/web",
    "typecheck:api": "npm run typecheck -w @vibenovel/api",
    "preview:web": "npm run preview -w @vibenovel/web",
    "smoke:api": "powershell -ExecutionPolicy Bypass -File scripts/sprint2-smoke-api.ps1",
    "smoke:api:base": "powershell -ExecutionPolicy Bypass -File scripts/sprint2-smoke-api.ps1",
    "smoke:api:sprint5": "powershell -ExecutionPolicy Bypass -File scripts/sprint5-smoke-api.ps1",
    "smoke:api:sprint6": "powershell -ExecutionPolicy Bypass -File scripts/sprint6-smoke-api.ps1",
    "smoke:api:sprint7": "powershell -ExecutionPolicy Bypass -File scripts/sprint7-smoke-api.ps1",
    "smoke:api:sprint8": "powershell -ExecutionPolicy Bypass -File scripts/sprint8-smoke-api.ps1",
    "smoke:api:sprint9": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-api.ps1",
    "smoke:web": "powershell -ExecutionPolicy Bypass -File scripts/sprint3-smoke-web.ps1",
    "smoke:web:outline": "powershell -ExecutionPolicy Bypass -File scripts/sprint4-smoke-web.ps1",
    "smoke:web:write": "powershell -ExecutionPolicy Bypass -File scripts/sprint5-smoke-web.ps1",
    "smoke:web:write-ai": "powershell -ExecutionPolicy Bypass -File scripts/sprint8-smoke-web.ps1",
    "smoke:web:credit-ui": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:rewrite": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:sprint9": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1",
    "smoke:web:publish-ai": "powershell -ExecutionPolicy Bypass -File scripts/sprint9-smoke-web.ps1 -PublishAiOnly",
    "smoke:web:summary": "powershell -ExecutionPolicy Bypass -File scripts/sprint6-smoke-web.ps1",
    "smoke:web:publish": "powershell -ExecutionPolicy Bypass -File scripts/sprint7-smoke-web.ps1",
    "smoke:all:local": "powershell -ExecutionPolicy Bypass -File scripts/smoke-all-local.ps1",
    "smoke:all:local:full": "powershell -ExecutionPolicy Bypass -File scripts/smoke-all-local.ps1 -IncludeApiMode"
  },
  "engines": {
    "node": ">=18"
  }
}